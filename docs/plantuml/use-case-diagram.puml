@startuml Use Case Diagram - Team Kanban System

left to right direction
skinparam packageStyle rectangle

actor "Sinh viên\n(User)" as User

rectangle "Team Kanban System" {

  package "Authentication" {
    usecase "UC1: Đăng ký\nvà Đăng nhập" as UC1
  }

  package "Project Management" {
    usecase "UC2: Quản lý\nProjects" as UC2
    usecase "UC3: Quản lý\nMembers" as UC3
  }

  package "Task Management" {
    usecase "UC4: Quản lý\nTasks" as UC4
    usecase "UC5: Gán và\nNhận Tasks" as UC5
  }

  package "Search & Filter" {
    usecase "UC6: Tìm kiếm\nvà Lọc Tasks" as UC6
  }
}

' User connections
User --> UC1
User --> UC2
User --> UC3
User --> UC4
User --> UC5
User --> UC6

' Dependencies
UC2 ..> UC1 : <<requires>>
UC3 ..> UC2 : <<requires>>
UC4 ..> UC2 : <<requires>>
UC5 ..> UC4 : <<requires>>
UC6 ..> UC4 : <<requires>>

' Notes
note right of UC3
  Chỉ Owner mới có thể
  mời/xóa members
end note

note right of UC5
  Owner gán tasks
  Member tự nhận tasks
end note

@enduml
